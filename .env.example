# Environment Variables for Marketing Strategy Recommender

# Translation API Configuration
# Choose one of the following translation providers:

# 1. Google Translate API (Recommended for production)
# Get API key from: https://console.cloud.google.com/apis/library/translate.googleapis.com
NEXT_PUBLIC_GOOGLE_TRANSLATE_API_KEY=

# 2. LibreTranslate (Open-source alternative)
# Set to true to use LibreTranslate instead of Google Translate
NEXT_PUBLIC_USE_LIBRE_TRANSLATE=false
# Custom LibreTranslate server URL (optional, defaults to public instance)
NEXT_PUBLIC_LIBRE_TRANSLATE_URL=https://libretranslate.pussthecat.org

# Backend API Configuration (main app — strategy, campaigns, auth, etc.)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Smart Assistant Backend (deployed separately — has its own VM/IP)
# All /api/auth/*, /api/admin/*, /api/chat/*, /api/superadmin/* calls from
# the Smart Assistant feature use this URL exclusively.
NEXT_PUBLIC_SMART_ASSISTANT_URL=http://localhost:8000

# Strategy Generator API Configuration
NEXT_PUBLIC_STRATEGY_GENERATOR_URL=http://localhost:8002
# ── Backend API URLs (one per microservice) ──────────────────────────
# 1. Strategy Recommender (strategy + calendar + business profile)
NEXT_PUBLIC_STRATEGY_BASE_URL=http://localhost:8000

# 2. Campaign Performance Predictor + Smart Assistant (shared generic)
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# 3. Content Generator
NEXT_PUBLIC_CONTENT_API_URL=http://localhost:8000

# Campaign Performance Predictor API Configuration
NEXT_PUBLIC_CAMPAIGN_BASE_URL=http://localhost:5000

# Development Settings
NODE_ENV=development